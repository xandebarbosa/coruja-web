# ==========================================
# NEXT AUTH (Autenticação)
# ==========================================
# URL que o next-auth usa para se identificar 
NEXTAUTH_URL=http://192.168.0.251:3009

# Um segredo aleatório para o next-auth assinar seus próprios cookies de sessão
NEXTAUTH_SECRET="/9OLCTymCZRu2j0nOMb7p/yqaeELpo2XgzOOhqyoJAY="
# (Você pode usar um gerador de SHA256 online para criar um)

# ==========================================
# KEYCLOAK (Provedor do NextAuth)
# ==========================================
# O ID do client que você ACABOU de criar no Passo 2
KEYCLOAK_CLIENT_ID="coruja-web-client"
KEYCLOAK_CLIENT_SECRET="iDvYlAyQqVN6wYrgECcCudU4DKU7TPQu"
# URL do Keycloak (Baseado no seu compose anterior, porta 8180)
KEYCLOAK_ISSUER="http://192.168.0.251:8180/realms/radares-realm"
# O endereço PÚBLICO do Keycloak (como o NAVEGADOR do usuário o vê)
# Usado para construir as URLs de login/logout iDvYlAyQqVN6wYrgECcCudU4DKU7TPQu
NEXT_PUBLIC_KEYCLOAK_BASE_URL="http://192.168.0.251:8180"


# ==========================================
# API GATEWAY (Conexão com o Backend)
# ==========================================
# Aponta para o API Gateway, que está na porta 8080
NEXT_PUBLIC_API="/api"
# URL pública do seu API Gateway (Baseado no seu compose anterior, porta 8081)
NEXT_PUBLIC_API_URL=http://192.168.0.251:8081
NEXT_PUBLIC_WS_URL=http://192.168.0.251:8081