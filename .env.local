# --- Configurações do Keycloak ---

# O endereço INTERNO do Keycloak (como o servidor Next.js o vê)
#KEYCLOAK_ISSUER="http://localhost:8180/realms/radares-realm"
#KEYCLOAK_ISSUER=http://host.docker.internal:8180/realms/radares-realm
KEYCLOAK_ISSUER="http://192.168.0.6:8180/realms/radares-realm"
#KEYCLOAK_ISSUER="http://keycloak:8080/realms/radares-realm"

# O ID do client que você ACABOU de criar no Passo 2
KEYCLOAK_CLIENT_ID="coruja-web-client"

# O endereço PÚBLICO do Keycloak (como o NAVEGADOR do usuário o vê)
# Usado para construir as URLs de login/logout iDvYlAyQqVN6wYrgECcCudU4DKU7TPQu
NEXT_PUBLIC_KEYCLOAK_BASE_URL="http://192.168.0.6:8180"

KEYCLOAK_CLIENT_SECRET="iDvYlAyQqVN6wYrgECcCudU4DKU7TPQu"

# === URL da API ===
# Aponta para o API Gateway, que está na porta 8080
